{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "registry": { "type": "string" },
        "name": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string" }
      }
    },
    "replicaCount": { "type": "integer", "minimum": 1 },
    "logLevel": { "type": "string", "enum": ["debug", "info", "warn", "error"] },
    "server": {
      "type": "object",
      "properties": {
        "port": { "type": "integer" }
      }
    },
    "admin": {
      "type": "object",
      "properties": {
        "port": { "type": "integer" }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "interval": { "type": "string" },
        "scrapeTimeout": { "type": "string" }
      }
    },
    "routing": {
      "type": "object",
      "properties": {
        "store": { "type": "string", "enum": ["memory", "bolt", "configmap"] },
        "boltPath": { "type": "string" },
        "defaultTTL": { "type": "string" },
        "autoCreate": { "type": "boolean" }
      }
    },
    "lifecycle": {
      "type": "object",
      "properties": {
        "driver": { "type": "string", "enum": ["klausctl", "operator"] },
        "klausctlBin": { "type": "string" },
        "operatorMCPURL": { "type": "string" },
        "operatorMCPToken": { "type": "string" }
      }
    },
    "upstream": {
      "type": "object",
      "properties": {
        "agentgatewayURL": { "type": "string" }
      }
    },
    "observability": {
      "type": "object",
      "properties": {
        "otlpEndpoint": { "type": "string" }
      }
    },
    "agentgateway": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "gatewayClassName": { "type": "string" },
        "gateway": {
          "type": "object",
          "properties": {
            "create": { "type": "boolean" },
            "parentRefs": { "type": "array" },
            "listeners": { "type": "array" },
            "annotations": { "type": "object" }
          }
        },
        "routes": {
          "type": "object",
          "properties": {
            "chatAndMcp": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "prefixes": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            "directInstance": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" }
              }
            }
          }
        },
        "policy": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "jwt": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "mode": { "type": "string", "enum": ["Strict", "Optional", "Permissive"] },
                "issuer": { "type": "string" },
                "audiences": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "jwks": {
                  "type": "object",
                  "properties": {
                    "mode": { "type": "string", "enum": ["inline", "remote"] },
                    "inline": { "type": "string" },
                    "remote": {
                      "type": "object",
                      "properties": {
                        "jwksPath": { "type": "string" },
                        "cacheDuration": { "type": "string" },
                        "backendRef": {
                          "type": "object",
                          "properties": {
                            "group": { "type": "string" },
                            "kind": { "type": "string" },
                            "name": { "type": "string" },
                            "namespace": { "type": "string" },
                            "port": { "type": "integer" }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "backendsExample": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "name": { "type": "string" },
            "static": {
              "type": "object",
              "properties": {
                "host": { "type": "string" },
                "port": { "type": "integer" }
              }
            }
          }
        }
      }
    }
  }
}
