{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "registry": { "type": "string" },
        "name": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string" }
      }
    },
    "replicaCount": { "type": "integer", "minimum": 1 },
    "logLevel": { "type": "string", "enum": ["debug", "info", "warn", "error"] },
    "server": {
      "type": "object",
      "properties": {
        "port": { "type": "integer" }
      }
    },
    "admin": {
      "type": "object",
      "properties": {
        "port": { "type": "integer" }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "interval": { "type": "string" },
        "scrapeTimeout": { "type": "string" }
      }
    },
    "routing": {
      "type": "object",
      "properties": {
        "store": { "type": "string", "enum": ["memory", "bolt", "configmap"] },
        "boltPath": { "type": "string" },
        "defaultTTL": { "type": "string" },
        "autoCreate": { "type": "boolean" }
      }
    },
    "lifecycle": {
      "type": "object",
      "properties": {
        "driver": { "type": "string", "enum": ["klausctl", "operator"] },
        "klausctlBin": { "type": "string" },
        "operatorMCPURL": { "type": "string" },
        "operatorMCPToken": { "type": "string" }
      }
    },
    "upstream": {
      "type": "object",
      "properties": {
        "agentgatewayURL": { "type": "string" }
      }
    },
    "observability": {
      "type": "object",
      "properties": {
        "otlpEndpoint": { "type": "string" }
      }
    }
  }
}
